{
  "expo": {
    "name": "fluxo-financeiro",
    "slug": "fluxo-financeiro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/perfil.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/perfil.png",
      "resizeMode": "contain",
      "backgroundColor": "#062f4f"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/perfil.png",
        "backgroundColor": "#062f4f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/perfil.png"
    }
  }
}

